{
  "manifest_version": 3,
  "name": "JLPT Hijack",
  "version": "0.1.0",
  "description": "한국어 사이트에서 JLPT 단어를 자동으로 잡아냅니다",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "src/background/sw.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "css": ["src/content/styles.css"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["data/jmdict-n2.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
